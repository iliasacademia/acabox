#!/usr/bin/env bash
# install — The only sanctioned way to install software for a mini-application.
#
# Runs a package install on the host AND records the dependency in the target
# app's per-registry dependency file so it persists when the app folder is
# shared and is re-installable on a fresh workspace.
#
# Per-registry dependency files (the single source of truth for each registry):
#   pip    → .applications/<app>/requirements.txt       (standard pip format)
#   npm    → .applications/<app>/package.json           (dependencies field)
#   manual → .applications/<app>/setup/*.sh             (check-then-install setup scripts)
#
# Usage:
#   .applications/install <manager> <package> [<package>...] --app <dir_name>
#   .applications/install manual <script-path> --app <dir_name>
#
# Managers:
#   pip     Python packages installed into the shared Coscientist venv
#   npm     Node packages installed into the shared Coscientist npm prefix
#   manual  Idempotent bash script (must live under .applications/<app>/setup/)
#
# Examples:
#   .applications/install pip seaborn --app myApp
#   .applications/install pip 'pandas>=2.0' scipy --app myApp
#   .applications/install npm d3 --app myApp
#   .applications/install npm 'd3@^7.0' --app myApp
#   .applications/install manual .applications/myApp/setup/init-data.sh --app myApp
#
# NOTES:
# - This script is the ONLY way the agent should install software. Direct
#   `pip install` / `npm install` calls are blocked by a PreToolUse hook.
# - Downloading DATA (model weights, datasets, etc.) into the app folder does
#   not require this wrapper — use curl or wget to write directly into
#   .applications/<dir_name>/. Those files are app-local, not global installs.
# - npm packages install into a shared host prefix. `package.json` here is a
#   declarative manifest only — no per-app `node_modules` is created. esbuild
#   resolves bundled imports by adding the shared npm prefix to NODE_PATH.

set -euo pipefail

# Host install locations. Both are set in the agent-server's environment by
# the Electron host so the wrapper doesn't have to guess where they live.
# Fall back to common defaults if the env vars are missing so the script is
# still debuggable from a plain shell.
VENV_DIR="${COSCIENTIST_VENV_DIR:-}"
NPM_PREFIX="${COSCIENTIST_NPM_PREFIX:-}"

usage() {
  sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-1}"
}

err() { echo "install: $*" >&2; }

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
if [ $# -lt 1 ]; then usage 1; fi

case "$1" in
  -h|--help|help) usage 0 ;;
esac

MANAGER="$1"; shift
PACKAGES=()
APP=""

case "$MANAGER" in
  pip|npm|manual) ;;
  R|r|apt)
    err "$MANAGER installs are not supported on the host build."
    err "Use pip / npm, or write a manual setup script under .applications/<app>/setup/."
    exit 1
    ;;
  *)
    err "unknown manager: $MANAGER"
    err "supported: pip, npm, manual"
    exit 1
    ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    --app)
      APP="${2:-}"
      if [ -z "$APP" ]; then err "--app requires a value"; exit 1; fi
      shift 2
      ;;
    --help|-h)
      usage 0
      ;;
    --*)
      err "unknown flag: $1"; exit 1
      ;;
    *)
      PACKAGES+=("$1"); shift
      ;;
  esac
done

if [ -z "$APP" ]; then
  err "missing required flag: --app <dir_name>"
  err "every install must be associated with an app so it travels when the app is shared."
  exit 1
fi

if [ ${#PACKAGES[@]} -eq 0 ]; then
  err "no packages specified"
  exit 1
fi

APP_DIR=".applications/$APP"
if [ ! -d "$APP_DIR" ]; then
  err "app directory not found: $APP_DIR"
  err "create the app first (see the manage-mini-application skill)."
  exit 1
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Resolve the host pip binary. Prefers the bundled Coscientist venv passed in
# via COSCIENTIST_VENV_DIR; otherwise complains loudly so the user fixes the
# environment instead of accidentally polluting system Python.
resolve_pip() {
  if [ -n "$VENV_DIR" ] && [ -x "$VENV_DIR/bin/pip" ]; then
    echo "$VENV_DIR/bin/pip"
    return 0
  fi
  err "pip is unavailable — the Coscientist Python venv is not initialized."
  err "Open a notebook or restart the app to bootstrap it, then try again."
  exit 1
}

# Resolve the host npm binary and prefix. The prefix is where shared npm
# packages land so mini-app esbuild bundles can resolve them via NODE_PATH.
resolve_npm_prefix() {
  if [ -z "$NPM_PREFIX" ]; then
    err "COSCIENTIST_NPM_PREFIX is not set; cannot install npm packages."
    exit 1
  fi
  if ! command -v npm >/dev/null 2>&1; then
    err "npm is not installed on this system."
    err "Install Node.js (https://nodejs.org or 'brew install node') and try again."
    exit 1
  fi
  mkdir -p "$NPM_PREFIX"
}

# pip: append to requirements.txt, deduping by package base name.
record_pip() {
  local reqs="$APP_DIR/requirements.txt"
  touch "$reqs"
  for pkg in "$@"; do
    local base
    base=$(printf '%s' "$pkg" | sed -E 's/[<>=!~;[:space:]].*$//')
    if grep -qE "^${base}([<>=!~;[:space:]]|\$)" "$reqs" 2>/dev/null; then
      local tmp; tmp=$(mktemp)
      awk -v b="$base" -v full="$pkg" '
        BEGIN { re = "^" b "([<>=!~;[:space:]]|$)" }
        { if ($0 ~ re) print full; else print $0 }
      ' "$reqs" > "$tmp"
      mv "$tmp" "$reqs"
    else
      echo "$pkg" >> "$reqs"
    fi
  done
}

# Parse an npm spec (`name`, `name@range`, `@scope/name`, `@scope/name@range`)
# into NAME and VERSION globals.
parse_npm_spec() {
  local spec="$1"
  if [[ "$spec" == @* ]]; then
    if [[ "${spec:1}" == *"@"* ]]; then
      NAME="${spec%@*}"
      VERSION="${spec##*@}"
    else
      NAME="$spec"; VERSION=""
    fi
  else
    if [[ "$spec" == *"@"* ]]; then
      NAME="${spec%@*}"
      VERSION="${spec##*@}"
    else
      NAME="$spec"; VERSION=""
    fi
  fi
}

# Query the resolved installed version of a global npm package in our prefix.
npm_installed_version() {
  local name="$1"
  npm list -g --prefix "$NPM_PREFIX" --depth=0 --json "$name" 2>/dev/null \
    | jq -r --arg n "$name" '.dependencies[$n].version // empty' 2>/dev/null \
    || echo ""
}

# npm: update dependencies field of package.json with semver caret ranges.
record_npm() {
  local pkgjson="$APP_DIR/package.json"
  if [ ! -f "$pkgjson" ]; then
    jq -n --arg n "$APP" '{name:$n, private:true, dependencies:{}}' > "$pkgjson"
  fi
  for spec in "$@"; do
    parse_npm_spec "$spec"
    local recorded="$VERSION"
    if [ -z "$recorded" ]; then
      local installed; installed=$(npm_installed_version "$NAME")
      if [ -n "$installed" ]; then recorded="^$installed"; else recorded="*"; fi
    fi
    local tmp; tmp=$(mktemp)
    jq --arg n "$NAME" --arg v "$recorded" \
       '.dependencies //= {} | .dependencies[$n] = $v' "$pkgjson" > "$tmp"
    mv "$tmp" "$pkgjson"
  done
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "$MANAGER" in
  pip)
    PIP_BIN=$(resolve_pip)
    echo "install: pip install ${PACKAGES[*]}"
    "$PIP_BIN" install --disable-pip-version-check --no-input "${PACKAGES[@]}"
    record_pip "${PACKAGES[@]}"
    echo "install: recorded in $APP_DIR/requirements.txt"
    ;;

  npm)
    resolve_npm_prefix
    echo "install: npm install -g --prefix $NPM_PREFIX ${PACKAGES[*]}"
    npm install -g --prefix "$NPM_PREFIX" --no-audit --no-fund "${PACKAGES[@]}"
    record_npm "${PACKAGES[@]}"
    echo "install: recorded in $APP_DIR/package.json"
    ;;

  manual)
    if [ ${#PACKAGES[@]} -ne 1 ]; then
      err "manual takes exactly one argument: the path to the script"
      exit 1
    fi
    SCRIPT_PATH="${PACKAGES[0]}"
    EXPECTED_PREFIX="$APP_DIR/setup/"
    if [[ "$SCRIPT_PATH" != "$EXPECTED_PREFIX"* ]]; then
      err "setup scripts must live under $EXPECTED_PREFIX"
      err "got: $SCRIPT_PATH"
      exit 1
    fi
    if [ ! -f "$SCRIPT_PATH" ]; then
      err "script not found: $SCRIPT_PATH"
      exit 1
    fi
    echo "install: running manual script $SCRIPT_PATH"
    echo "install: NOTE — manual scripts must check-then-install (detect if already present and exit 0)." >&2
    bash "$SCRIPT_PATH"
    echo "install: recorded by presence of $SCRIPT_PATH"
    ;;
esac
