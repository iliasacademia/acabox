# Environment variables for local code signing and notarization
# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and will not be committed

# Your Apple Developer ID certificate identity name
# You can find this by running: security find-identity -v -p codesigning
# Example: "Developer ID Application: Your Company Name (XXXXXXXXXX)"
APPLE_IDENTITY="Developer ID Application: Your Company Name (XXXXXXXXXX)"

# Your Apple ID email (used for notarization)
APPLE_ID="your-apple-id@example.com"

# App-specific password for notarization
# Create one at: https://appleid.apple.com/account/manage
# Go to "Security" > "App-Specific Passwords" > "Generate Password"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Your Apple Developer Team ID
# Find this at: https://developer.apple.com/account (Membership Details)
APPLE_TEAM_ID="XXXXXXXXXX"

# =============================================================================
# Datadog RUM (Real User Monitoring) Configuration
# =============================================================================

# Datadog RUM Application ID
# Get from: https://app.datadoghq.com/rum/application/create
DATADOG_APPLICATION_ID="your_application_id_here"

# Datadog Client Token (safe to bundle in packaged apps)
# Get from: https://app.datadoghq.com/organization-settings/client-tokens
# Client tokens start with "pub" prefix and are designed to be public
DATADOG_CLIENT_TOKEN="pub_your_client_token_here"

# Datadog site (region) - defaults to datadoghq.com if not set
# Options: datadoghq.com (US), datadoghq.eu (EU), us3.datadoghq.com, us5.datadoghq.com
DATADOG_SITE="datadoghq.com"

# Enable Datadog logging in development (default: false in dev, true in production)
# Set to "true" to test Datadog integration locally
DATADOG_ENABLED="false"

# =============================================================================
# Zendesk Web Widget Configuration
# =============================================================================

# Zendesk Widget Key (safe to bundle in packaged apps - it's a public key)
# Get from: Zendesk Admin Center > Channels > Messaging and social > Messaging
# Click on your widget > Installation > Web Widget (Messenger)
ZENDESK_WIDGET_KEY="your_widget_key_here"

# Enable Zendesk widget (default: false in dev, true in production)
# Set to "true" to test Zendesk integration locally
ZENDESK_ENABLED="false"
