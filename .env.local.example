# Environment variables for local code signing and notarization
# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and will not be committed

# Your Apple Developer ID certificate identity name
# You can find this by running: security find-identity -v -p codesigning
# Example: "Developer ID Application: Your Company Name (XXXXXXXXXX)"
APPLE_IDENTITY="Developer ID Application: Your Company Name (XXXXXXXXXX)"

# Your Apple ID email (used for notarization)
APPLE_ID="your-apple-id@example.com"

# App-specific password for notarization
# Create one at: https://appleid.apple.com/account/manage
# Go to "Security" > "App-Specific Passwords" > "Generate Password"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Your Apple Developer Team ID
# Find this at: https://developer.apple.com/account (Membership Details)
APPLE_TEAM_ID="XXXXXXXXXX"
