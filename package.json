    "exceljs": "^4.4.0",
    "form-data": "^4.0.3",
    "html-react-parser": "^6.1.0",
    "http-cookie-agent": "^7.0.2",
    "isomorphic-dompurify": "^2.32.0",
    "loglayer": "^8.1.0",
    "lucide-react": "^1.7.0",
    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
