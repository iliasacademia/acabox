{
  "name": "academia-electron",
  "productName": "Writing Agent",
  "version": "0.0.1",
  "browserExtensionVersion": "0.3.5",
  "description": "Demo Academia Electron App",
  "main": ".webpack/main",
  "scripts": {
    "build": "npm run build:native && npm run build:popup && npm run build:agent-server",
    "build:agent-server": "webpack --config webpack.agent-server.config.js",
    "build:native": "node scripts/build-native-safe.js",
    "build:popup": "webpack --config webpack.popup.config.js",
    "build:popup:watch": "webpack --config webpack.popup.config.js --watch",
    "download-podman": "bash scripts/download-podman-binaries.sh",
    "download-browser-extension": "bash scripts/download-browser-extension.sh",
    "prestart": "npm run build:native && npm run build:popup",
    "start": "dotenv -e .env.local -- cross-env NODE_ENV=development electron-forge start",
    "prestart:cobuilding": "cd src/cobuilding/rust/file-monitor-mac && cargo build",
    "start:cobuilding": "dotenv -e .env.local -- cross-env NODE_ENV=development ENTRY_POINT=cobuilding electron-forge start",
    "build:cobuilding:rust": "node scripts/build-cobuilding-rust.js",
    "cleanup": "./cleanup.sh",
    "test:cleanup": "./test-cleanup.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:applescript": "find src/applescripts -name '*.applescript' -exec osacompile -o /dev/null {} \\;",
    "test": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest",
    "test:cobuilding": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest --testPathPatterns=src/cobuilding",
    "test:watch": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest --watch",
    "test:coverage": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest --coverage",
    "test:window-monitor": "node window-monitor/test/window-monitor-macos-test.js",
    "cleanup:sessions": "node scripts/cleanup-sessions.js",
    "db:dev": "sqlite3 -column -header ~/Library/Application\\ Support/academia-electron/sessions-dev.db",
    "db:cobuilding:reset": "rm -f ~/Library/Application\\ Support/academia-electron/development/cobuilding.db",
    "cobuilding:build-container": "podman build -t cobuilding-container -f src/cobuilding/Dockerfile src/cobuilding",
    "cobuilding:build-container:full": "podman build -t cobuilding-base:local -f src/cobuilding/Dockerfile.base src/cobuilding && podman build --build-arg BASE_IMAGE=cobuilding-base:local -t cobuilding-container -f src/cobuilding/Dockerfile src/cobuilding",
    "prebuild": "npm run build:native && npm run build:popup",
    "package": "electron-forge package",
    "codesign": "find out -name '*.app' -maxdepth 2 -type d -exec codesign --force --deep --sign - --identifier com.electron.academia-electron {} \\;",
    "package:sign": "npm run package && npm run codesign",
    "make": "electron-forge make",
    "make:sign": "npm run make && npm run codesign",
    "logs:dev:watch": "tail -f ~/Library/Logs/academia-electron/main-dev.log",
    "logs:stable:watch": "tail -f ~/Library/Logs/academia-electron/main-stable.log",
    "logs:beta:watch": "tail -f ~/Library/Logs/academia-electron/main-beta.log",
    "reset-permissions": "tccutil reset All com.electron.academia-electron",
    "fresh-install": "rm -rf /Applications/academia-electron.app; tccutil reset All com.electron.academia-electron; rm -rf ~/Library/Preferences/com.electron.academia-electron* ~/Library/Application\\ Support/academia-electron ~/Library/Application\\ Support/com.electron.academia-electron* ~/Library/Caches/com.electron.academia-electron ~/Library/Logs/academia-electron out/",
    "check:native-deps": "node scripts/check-native-deps.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && bash scripts/ensure-linux-claude-binary.sh"
  },
  "author": "Academia.edu",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "^2.2.0",
    "@types/auto-launch": "^5.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.7.2",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "babel-jest": "^30.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "dotenv-cli": "^11.0.0",
    "electron": "^37.2.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.39.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.5.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "undici": "^7.16.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@anthropic-ai/sdk": "^0.82.0",
    "@assistant-ui/react": "^0.12.22",
    "@assistant-ui/react-markdown": "^0.12.8",
    "@aws-sdk/client-bedrock-runtime": "^3.1023.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@fullstory/browser": "^2.0.6",
    "@googleapis/calendar": "^14.2.0",
    "@jupyterlab/services": "^7.5.6",
    "@loglayer/transport-electron-log": "^2.1.13",
    "@loglayer/transport-http": "^1.1.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.0.5",
    "anser": "^2.3.5",
    "auto-launch": "^5.0.6",
    "axios": "1.10.0",
    "axios-cookiejar-support": "^6.0.4",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.0",
    "chokidar": "^4.0.3",
    "codemirror": "^6.0.2",
    "codemirror-lang-r": "^0.1.1",
    "cron-parser": "^5.5.0",
    "diff": "^8.0.4",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.1",
