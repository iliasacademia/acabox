{
  "name": "acabox",
  "productName": "Acabox",
  "private": true,
  "version": "0.0.1",
  "description": "Acabox desktop app — local-file-aware research assistant with mini-app hosting.",
  "main": ".webpack/main",
  "scripts": {
    "build": "npm run build:agent-server",
    "build:agent-server": "webpack --config webpack.agent-server.config.js",
    "prestart": "node scripts/rename-dev-electron.js && node scripts/build-cobuilding-prestart.js",
    "start": "dotenv -e .env.local -- cross-env NODE_ENV=development electron-forge start",
    "build:cobuilding:rust": "node scripts/build-cobuilding-rust.js",
    "cleanup": "./cleanup.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest",
    "test:watch": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest --watch",
    "test:coverage": "ELECTRON_RUN_AS_NODE=1 electron node_modules/.bin/jest --coverage",
    "db:cobuilding:reset": "rm -f ~/Library/Application\\ Support/acabox/development/cobuilding.db*",
    "prepackage": "npm run build:agent-server",
    "package": "electron-forge package",
    "codesign": "find out -name '*.app' -maxdepth 2 -type d -exec codesign --force --deep --sign - --identifier com.electron.acabox {} \\;",
    "package:sign": "npm run package && npm run codesign",
    "premake": "npm run build:agent-server",
    "make": "electron-forge make",
    "make:sign": "npm run make && npm run codesign",
    "logs:dev:watch": "tail -f ~/Library/Logs/Acabox/main-dev.log",
    "fresh-install": "rm -rf /Applications/Acabox.app; tccutil reset All com.electron.acabox; rm -rf ~/Library/Preferences/com.electron.acabox* ~/Library/Application\\ Support/acabox ~/Library/Application\\ Support/com.electron.acabox* ~/Library/Caches/com.electron.acabox ~/Library/Logs/Acabox out/",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "author": "Academia.edu",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "^2.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/webpack-plugin": "^5.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.7.2",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "babel-jest": "^30.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
