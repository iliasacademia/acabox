    "latex.js": "^0.12.6",
    "loglayer": "^8.1.0",
    "lucide-react": "^1.7.0",
    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
    "markdown-to-jsx": "^8.0.0",
    "onnxruntime-node": "~1.23.2",
