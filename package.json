{
  "name": "academia-electron",
  "version": "0.0.1",
  "description": "Demo Academia Electron App",
  "main": ".webpack/main",
  "scripts": {
    "build": "npm run build:native && npm run build:popup",
    "build:native": "node scripts/build-native-safe.js",
    "build:popup": "webpack --config webpack.popup.config.js",
    "build:popup:watch": "webpack --config webpack.popup.config.js --watch",
    "prestart": "npm run build:native && npm run build:popup",
    "start": "dotenv -e .env.local -- cross-env NODE_ENV=development electron-forge start",
    "cleanup": "./cleanup.sh",
    "test:cleanup": "./test-cleanup.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:applescript": "find src/applescripts -name '*.applescript' -exec osacompile -o /dev/null {} \\;",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:native": "cd src/native && ./run-simple-tests.sh",
    "prebuild": "npm run build:native && npm run build:popup",
    "package": "electron-forge package",
    "codesign": "find out -name '*.app' -maxdepth 2 -type d -exec codesign --force --deep --sign - --identifier com.electron.academia-electron {} \\;",
    "package:sign": "npm run package && npm run codesign",
    "make": "electron-forge make",
    "make:sign": "npm run make && npm run codesign",
    "logs:dev:watch": "tail -f ~/Library/Logs/academia-electron/main-dev.log",
    "logs:stable:watch": "tail -f ~/Library/Logs/academia-electron/main-stable.log",
    "logs:beta:watch": "tail -f ~/Library/Logs/academia-electron/main-beta.log",
    "reset-permissions": "tccutil reset All com.electron.academia-electron",
    "fresh-install": "rm -rf /Applications/academia-electron.app; tccutil reset All com.electron.academia-electron; rm -rf ~/Library/Preferences/com.electron.academia-electron* ~/Library/Application\\ Support/academia-electron ~/Library/Application\\ Support/com.electron.academia-electron* ~/Library/Caches/com.electron.academia-electron ~/Library/Logs/academia-electron out/"
  },
  "author": "Academia.edu",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "^2.2.0",
    "@types/auto-launch": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "babel-jest": "^30.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "dotenv-cli": "^11.0.0",
    "electron": "^37.2.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.39.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.5.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "undici": "^7.16.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.24.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "@loglayer/transport-electron-log": "^2.1.13",
    "@loglayer/transport-http": "^1.1.8",
    "@types/dompurify": "^3.0.5",
    "auto-launch": "^5.0.6",
    "axios": "^1.10.0",
    "axios-cookiejar-support": "^6.0.4",
    "canvas": "^3.2.0",
    "chokidar": "^4.0.3",
    "diff": "^8.0.2",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "fastify": "^5.6.1",
    "form-data": "^4.0.3",
    "http-cookie-agent": "^7.0.2",
    "isomorphic-dompurify": "^2.32.0",
    "loglayer": "^8.1.0",
    "markdown-to-jsx": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-diff-view": "^3.3.2",
    "react-dom": "^19.2.0",
    "serialize-error": "^12.0.0",
    "tesseract.js-core": "^6.0.0",
    "tough-cookie": "^5.1.2",
    "tough-cookie-file-store": "^3.2.1"
  }
}
